{
  "name": "revel",
  "version": "3.0.1",
  "description": "Revel - Mole CLI 的 Fluent Design 图形界面",
  "main": "./dist/main/main.js",
  "author": "a1121611810",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/a1121611810/revel.git"
  },
  "bugs": {
    "url": "https://github.com/a1121611810/revel/issues"
  },
  "homepage": "https://github.com/a1121611810/revel#readme",
  "packageManager": "pnpm@11.5.0",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "preview": "electron .",
    "postinstall": "simple-git-hooks",
    "build:mac": "electron-forge make --platform=darwin",
    "build:win": "electron-forge make --platform=win32",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "test:browser:watch": "vitest --config vitest.browser.config.js",
    "test:e2e": "pnpm build && playwright test tests/e2e",
    "test:e2e:ui": "pnpm build && playwright test tests/e2e --ui",
    "test:e2e:debug": "pnpm build && playwright test tests/e2e --debug",
    "test:all": "pnpm test && pnpm test:browser && pnpm test:e2e",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "oxfmt src/",
    "format:check": "oxfmt src/ --check",
    "quality": "pnpm lint && pnpm format:check && pnpm test",
    "quality:fix": "pnpm lint:fix && pnpm format",
    "licenses:generate": "node scripts/generate-licenses.mjs",
    "export-icons": "node scripts/export-icons.mjs"
  },
  "dependencies": {
    "vue-i18n": "^11.4.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^2.1.2",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.0",
    "electron": "^42.3.0",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^0.16.0",
    "playwright": "^1.60.0",
    "png2icons": "^2.0.1",
    "simple-git-hooks": "^2.11.1",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "vue": "^3.4.0"
  },
  "config": {
    "forge": "./forge.config.js"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/oxlint src/ && ./node_modules/.bin/oxfmt src/ --check"
  }
}
